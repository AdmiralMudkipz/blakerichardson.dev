# ==========================================================
# .gitignore — Only track campaign & portfolio page assets
# ==========================================================

# --- Python bytecode & cache ---
__pycache__/
*.py[cod]
*$py.class
*.so

# --- Virtual environments ---
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# --- Django generated / local-only files ---
*.log
db.sqlite3
db.sqlite3-journal
local_settings.py

# --- Unrelated apps (starter/demo apps, not used by campaign or portfolio) ---
basic/
htmx/
tasks/
staticfiles/

# --- Unrelated project files ---
# fixture.py seeds data for basic & tasks apps only
fixture.py
# static/ contains nasa_imageurls used only by the htmx demo
static/

# --- Misc junk files ---
*.bak
*.pptx
*.m4a

# --- Unused duplicate media (templates reference /media/ root, not these) ---
media/img/
media/profilepic.png

# --- Unused duplicate resumes (templates link to /media/resume_*.pdf instead) ---
portfolio/Resumes/

# --- Stray duplicate images in portfolio root ---
portfolio/banner.jpeg
portfolio/profilepic.jpeg

# --- Empty default scaffolding files ---
portfolio/tests.py

# --- OS / IDE ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# --- Packaging / build artifacts ---
*.egg-info/
*.egg
dist/
build/
.Python
*.manifest
*.spec
MANIFEST
